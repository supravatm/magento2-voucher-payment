<?xml version="1.0"?>
<schema xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" 
        xsi:noNamespaceSchemaLocation="urn:magento:framework:Setup/Declaration/Schema/etc/schema.xsd">
  <table name="quote_payment">
    <column xsi:type="varchar" name="voucher_number" nullable="true" length="255" comment="Voucher Number"/>
  </table>
  <table name="sales_order_payment">
      <column xsi:type="varchar" name="voucher_number" nullable="true" length="32" comment="Voucher Number"/>
  </table>

  <table name="smg_voucher" resource="default" engine="innodb"
           comment="Voucher Management">

        <column xsi:type="int"
                name="entity_id"
                unsigned="true"
                nullable="false"
                identity="true"
                comment="Entity ID"/>

        <column xsi:type="varchar"
                name="voucher_number"
                nullable="false"
                length="100"
                comment="Voucher Number"/>

        <column xsi:type="smallint"
                name="is_active"
                nullable="false"
                default="1"
                comment="Is Active"/>

        <column xsi:type="datetime"
                name="valid_from"
                nullable="true"
                comment="Valid From"/>

        <column xsi:type="datetime"
                name="valid_to"
                nullable="true"
                comment="Valid To"/>

        <column xsi:type="int"
                name="usage_limit"
                nullable="false"
                default="1"
                comment="Maximum Usage"/>

        <column xsi:type="int"
                name="times_used"
                nullable="false"
                default="0"
                comment="Times Used"/>

        <column xsi:type="smallint"
                name="is_single_use"
                nullable="false"
                default="1"
                comment="Single Use Voucher"/>

        <column xsi:type="timestamp"
                name="created_at"
                nullable="false"
                default="CURRENT_TIMESTAMP"
                on_update="false"
                comment="Created At"/>

        <column xsi:type="timestamp"
                name="updated_at"
                nullable="false"
                default="CURRENT_TIMESTAMP"
                on_update="true"
                comment="Updated At"/>

        <constraint xsi:type="primary"
                    referenceId="PRIMARY">
            <column name="entity_id"/>
        </constraint>

        <constraint xsi:type="unique"
                    referenceId="SMG_VOUCHER_VOUCHER_NUMBER_UNIQUE">
            <column name="voucher_number"/>
        </constraint>

        <index referenceId="SMG_VOUCHER_ACTIVE_IDX"
               indexType="btree">
            <column name="is_active"/>
        </index>

        <index referenceId="SMG_VOUCHER_VALID_TO_IDX"
               indexType="btree">
            <column name="valid_to"/>
        </index>

    </table>
</schema>